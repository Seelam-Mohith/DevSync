PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/devsync?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_strong_secret_min_32_chars_in_production
CLIENT_URL=http://localhost:5173
NODE_ENV=development
GITHUB_TOKEN=your_github_personal_access_token_optional_but_needed_for_contributions

# Codolio Configuration (Optional)
CODOLIO_API_TIMEOUT=5000
CODOLIO_SCRAPE_TIMEOUT=10000
CODOLIO_CACHE_TTL=3600
